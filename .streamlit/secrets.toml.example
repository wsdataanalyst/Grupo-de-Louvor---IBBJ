# Copie para secrets.toml OU execute: python setup_onesignal.py
# No Streamlit Cloud: Settings → Secrets (mesmo conteúdo)

public_url = "https://seu-app.streamlit.app"

# Persistência na nuvem (recomendado em produção) — guia: CONFIGURAR_SUPABASE.md
# [persistence]
# enabled = true
# supabase_url = "https://SEU-PROJETO.supabase.co"
# supabase_key = "COLE-A-SERVICE-ROLE-KEY-AQUI"

# OneSignal — https://onesignal.com (guia: CONFIGURAR_ONESIGNAL.md)
push_notifications_enabled = true
onesignal_app_id = "COLE-SEU-APP-ID-AQUI"
onesignal_rest_api_key = "COLE-SUA-REST-API-KEY-AQUI"

# WhatsApp — ao salvar escala, abre conversa com mensagem completa (confirme envio no grupo)
# group_phone = DDI+DDD+número só dígitos (ex.: líder ou número vinculado ao grupo)
[whatsapp]
group_phone = "5511999999999"
auto_prompt_on_save = true

# Desenvolvedor (Gerenciar Escalas + painel de teste de push)
developer_emails = ["wsdataanalyst", "willsousaa7x@gmail.com"]
dev_default_password = "IbbjDev2024"

# E-mail automático (OPCIONAL) — o jeito fácil é o líder redefinir no app (Membros)
# Resend (recomendado, 1 chave): https://resend.com — grátis ~100 e-mails/dia
# resend_api_key = "re_xxxxxxxx"
# resend_from_email = "Louvor IBBJ <onboarding@resend.dev>"

# Ou Gmail SMTP (mais chato): Senha de app em https://myaccount.google.com/apppasswords
[smtp]
enabled = true
host = "smtp.gmail.com"
port = 587
user = "seu-email@gmail.com"
password = "SUA-SENHA-DE-APP"
from_email = "Grupo de Louvor IBBJ <seu-email@gmail.com>"
use_tls = true
