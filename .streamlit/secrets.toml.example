# Copie para secrets.toml OU execute: python setup_onesignal.py
# No Streamlit Cloud: Settings → Secrets (mesmo conteúdo)

public_url = "https://seu-app.streamlit.app"

# OneSignal — https://onesignal.com (guia: CONFIGURAR_ONESIGNAL.md)
push_notifications_enabled = true
onesignal_app_id = "COLE-SEU-APP-ID-AQUI"
onesignal_rest_api_key = "COLE-SUA-REST-API-KEY-AQUI"

# Desenvolvedor (Gerenciar Escalas + painel de teste de push)
developer_emails = ["wsdataanalyst", "willsousaa7x@gmail.com"]
dev_default_password = "IbbjDev2024"

# E-mail — recuperação de senha ("Esqueci minha senha")
# Gmail: use "Senha de app" em https://myaccount.google.com/apppasswords
[smtp]
enabled = true
host = "smtp.gmail.com"
port = 587
user = "seu-email@gmail.com"
password = "SUA-SENHA-DE-APP"
from_email = "Grupo de Louvor IBBJ <seu-email@gmail.com>"
use_tls = true
